# Copier vers .env : cp .env.example .env
# Ne jamais committer .env (secrets).

# --- HTTP ---
PORT=3000
NODE_ENV=development

# --- Risk engine ---
RISK_MIN_AGGREGATE_SCORE=60

# --- Uniswap Labs Trade API (obligatoire : le serveur ne démarre pas sans) ---
# URL du gateway : fixe dans le code (`https://trade-api.gateway.uniswap.org`).
UNISWAP_API_KEY=remplace_par_ta_cle_uniswap_labs
